        <mxCell id="cEf5rpYRRotUU9M173kf-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;gradientColor=#d5739d;strokeColor=#996185;" value="Тестировщий" vertex="1">
