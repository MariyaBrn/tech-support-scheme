        </mxCell>
        <mxCell id="t-0UggL7TuAT3XfV_KT_-27" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;gradientColor=#97d077;strokeColor=#82b366;" value="&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Консультант&lt;/span&gt;" vertex="1">
