        <mxCell id="t-0UggL7TuAT3XfV_KT_-32" parent="1" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#e6d0de;gradientColor=#d5739d;strokeColor=#996185;" value="Менеджер проекта" vertex="1">
          <mxGeometry height="60" width="120" x="780" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="t-0UggL7TuAT3XfV_KT_-33" edge="1" parent="1" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#a20025;strokeColor=#6F0000;" value="">
