        <mxCell id="cEf5rpYRRotUU9M173kf-57" edge="1" parent="1" source="cEf5rpYRRotUU9M173kf-20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" target="cEf5rpYRRotUU9M173kf-37">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;gradientColor=#d5739d;strokeColor=#996185;" value="Менеджер проекта" vertex="1">
          <mxGeometry height="60" width="120" x="640" y="1490" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b0e3e6;strokeColor=#0e8088;" value="&lt;ul&gt;&lt;li&gt;Приём входящих звонков и обращений&amp;nbsp;&lt;/li&gt;&lt;li&gt;Регистрация обращений в Service Desk&lt;/li&gt;&lt;li&gt;Консультирование пользователей с стандартными запросами(по инструкциям и памяткам)&lt;/li&gt;&lt;li&gt;Уточнение информации у пользователя&lt;/li&gt;&lt;li&gt;Первичная диагностика&lt;/li&gt;&lt;li&gt;Классификация и приоритизация заявок&lt;/li&gt;&lt;li&gt;Эскалация на другие линии поддержки, если обращение не было решено за 15-20 минут или нет компетенций для решения&lt;/li&gt;&lt;li&gt;Уведомление пользователя о решении обращения&lt;/li&gt;&lt;li&gt;Закрытие обращения&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="840" y="-280" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-28" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;ul&gt;&lt;li&gt;Исследует сложные обращения&lt;/li&gt;&lt;li&gt;Контроль соблюдения SLA по заявкам 2 линии&lt;/li&gt;&lt;li&gt;Подготовка скриптов и инструкций для 1 линии&lt;/li&gt;&lt;li&gt;Проведение обучения Консультантов&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="840" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;ul&gt;&lt;li&gt;Мониторинг доступности API&lt;/li&gt;&lt;li&gt;Контроль соблюдения SLA и времени решения задачи&lt;/li&gt;&lt;li&gt;Координация между линиями поддержки&lt;/li&gt;&lt;li&gt;Коммуникация с Поставщиками по вопросам API&lt;/li&gt;&lt;li&gt;Управление приоритетами заявок&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="242.5" width="280" x="850" y="560" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-37" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#fad9d5;strokeColor=#ae4132;" value="&lt;ul&gt;&lt;li&gt;Управление релизами изменений&lt;/li&gt;&lt;li&gt;Планирование и контроль выполнения сроков решения&lt;/li&gt;&lt;li&gt;Координация работ разработки с поддержкой&lt;/li&gt;&lt;li&gt;Коммуникация с заказчиком по срокам исправления критических ошибок&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="840" y="1400" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-39" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#d0cee2;strokeColor=#56517e;" value="&lt;ul&gt;&lt;li&gt;Воспроизведение ошибок для подтверждения дефектов&lt;/li&gt;&lt;li&gt;Проверка&amp;nbsp; корректности исправлений перед релизом - тестирование функционала&lt;/li&gt;&lt;li&gt;Участие в анализе сложных инцидентов&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="840" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-35" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#fad9d5;strokeColor=#ae4132;" value="&lt;ul&gt;&lt;li&gt;Решение сложных инцидентов, требующих изменения и доработки кода&lt;/li&gt;&lt;li&gt;Доработка функционала&lt;/li&gt;&lt;li&gt;Исправление ошибок в API&amp;nbsp; и модулях приема данных&lt;/li&gt;&lt;li&gt;Планирование и реализация запросов на изменение&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="840" y="840" as="geometry" />
        </mxCell>
        <mxCell id="cEf5rpYRRotUU9M173kf-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;ul&gt;&lt;li&gt;Анализ обращений и инцидентов&lt;/li&gt;&lt;li&gt;Выявление корневых причин ошибок&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Постановка задач на исправление ошибок для 3 линии&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Разработка технологических инструкций для 1 линии&lt;/li&gt;&lt;li&gt;Взаимодействие с Разработчиками и Тестировщиками&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="242.5" width="280" x="840" y="280" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="GIlO7T2_UgoPZls0A30E" name="Описание обработки обращений">
