        <mxCell id="t-0UggL7TuAT3XfV_KT_-22" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Вариант 1" vertex="1">
